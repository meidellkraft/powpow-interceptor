{
	"manifest_version": 3,
	"name": "PowPow Interceptor",
	"version": "0.1.1",
	"description": "Enhanced Power Pages pro code developer experience.",
	"permissions": [
		"storage",
		"debugger",
		"tabs"
	],
	"host_permissions": [
		"http://localhost/*"
	],
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"action": {
		"default_popup": "index.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"24": "icons/icon24.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"64": "icons/icon64.png",
			"96": "icons/icon96.png",
			"128": "icons/icon128.png",
			"256": "icons/icon256.png",
			"512": "icons/icon512.png"
		}
	}
}
